// best time to buy or sell stock problem 30

#include<iostream>
using namespace std;

int main(){
    int arr[6] = {7,1,5,3,6,4};
    int n = sizeof(arr)/sizeof(arr[0]);
    int max_profit = 0;
    
    for(int i = 0; i < n; i++){
        for(int j = i+1; j < n; j++){
            int profit = arr[j] - arr[i];
            if(profit > max_profit){
                max_profit = profit;
            }
        }
    }
    cout << max_profit << endl;
    return 0;
}