// trapping rain water problem 28

#include<iostream>
using namespace std;

int main(){
    int arr[6] {3,0,0,2,0,4};
    int n = sizeof(arr)/sizeof(arr[0]);
    int right_max = 0;
    int left_max = 0;
    int mid = n/2;
    int water = 0;
    
    for(int i = 0; i < mid; i++){
        if(arr[i] > right_max){
            right_max = arr[i];
        }
    }
    for(int j = mid; j < n; j++){
        if(arr[j] > left_max){
            left_max = arr[j];
        }
    }

    for(int k = 0; k < n; k++){
        if(arr[k] == arr[0]){
            water = 0;
        }
        else{
            water += min(right_max, left_max) - arr[k];
        }
    }
    
    cout << << "Total water : " << water << endl;
    return 0;
}