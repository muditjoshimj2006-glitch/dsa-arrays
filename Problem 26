// more than n/k occurrence problem 26

#include<iostream>
using namespace std;

int main(){
    int arr[8] = {8,1,2,3,12,1,1,1};
    int n = sizeof(arr)/sizeof(arr[0]);
    int k = 4;
    
    for(int i = 0; i < n; i++){
        int count = 0;
        for(int j = i+1; j < n; j++){
            if(arr[i] == arr[j]){
                count++;
                
            }
        }
        if(count > n/k){
        cout << "Element which occurs more than n/k times = " << arr[i] << endl;
       
    }
    
    }
    return 0;
}